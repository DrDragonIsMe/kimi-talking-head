# Kimi Code API configuration
# Get your key from https://platform.moonshot.cn/
KIMI_CODE_BASE_URL=https://api.kimi.com/coding/v1
KIMI_CODE_API_KEY=your-api-key-here
KIMI_CODE_MODEL=kimi-for-coding

# 火山方舟 API key（可选；视频窗口默认链路的 seedance_ark provider 使用，
# 缺失时自动跳过 ark 落到库存兜底，不会中断 pipeline）
# 从火山方舟控制台获取，需有 doubao-seedance 系列模型访问权限
ARK_API_KEY=
