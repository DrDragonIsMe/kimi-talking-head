# server/install.sh 依赖版本锁定表
#
# 背景：install.sh 历史上全部 `git clone --depth 1` 跟踪上游 HEAD，torch 不锁版本，
# 上游一动安装结果就漂移（已在 fp8 节点 400 回退事件上吃过亏，见 TEST_REPORT.md）。
#
# 用法：把经过实测的 commit SHA / tag 填到对应 *_REF，install.sh 会在 clone/pull 后
# 检出该版本。留空 = 保持现状（跟随 HEAD）。
#
# 建议工作流：新服务器安装验证通过后，把各仓库实际检出的 commit 回填到这里并提交，
# 之后的重装/扩容即可复现同一环境。
#
# 也可用同名环境变量覆盖（CI/临时测试）。

# ComfyUI 主体（comfyanonymous/ComfyUI）
COMFYUI_REF="${COMFYUI_REF:-}"

# ComfyUI 侧 PyTorch（pip 规格，空格分隔三个包；示例锁定：
# TORCH_SPEC="torch==2.6.0 torchvision==0.21.0 torchaudio==2.6.0"）
TORCH_SPEC="${TORCH_SPEC:-torch torchvision torchaudio}"

# ComfyUI 自定义节点
INFINITETALK_REF="${INFINITETALK_REF:-}"
WANVIDEO_REF="${WANVIDEO_REF:-}"
VIDEO_HELPER_REF="${VIDEO_HELPER_REF:-}"
KJ_NODES_REF="${KJ_NODES_REF:-}"
MANAGER_REF="${MANAGER_REF:-}"

# IndexTTS（index-tts/index-tts）
INDEX_TTS_REF="${INDEX_TTS_REF:-}"

# MuseTalk（TMElyralab/MuseTalk）；其 torch/mmcv/mmdet/mmpose 已在 install.sh 内锁定
MUSETALK_REF="${MUSETALK_REF:-}"
